# Data Wiz environment variables.
# Copy this file to `.env` for local dev. Never commit `.env` itself.
# In production (Render), set these via the dashboard, NOT a file on disk.

# ─── REQUIRED ─────────────────────────────────────────────────────────────────

# JWT signing secret. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# Render generates this automatically via render.yaml. Locally, set your own.
JWT_SECRET=change-me-to-a-long-random-string

# Where the frontend lives. Comma-separated list of allowed origins.
# Local dev (default): http://localhost:5173
# Production: https://your-app.vercel.app,https://your-app-git-main.vercel.app
CLIENT_URL=http://localhost:5173

# ─── OPTIONAL — environment ──────────────────────────────────────────────────

# Production mode toggles secure cookies, CSP, less-noisy logs.
# NODE_ENV=production

# Port the backend listens on. Default 8000 (Mac AirPlay-friendly).
PORT=8000

# Where SQLite + dataset files live. Local dev leaves this unset (uses
# ./server/data/). Production sets this to the persistent disk mount path.
# DATA_DIR=/var/data

# Behind a reverse proxy (Render, Heroku, etc.), set how many hops to trust.
# Locally, leave unset.
# TRUST_PROXY=1

# Override SameSite cookie behavior. Defaults: 'lax' in dev, 'none' in prod.
# 'none' is required when client and server are on different domains.
# COOKIE_SAMESITE=none

# ─── OPTIONAL — Anthropic LLM ────────────────────────────────────────────────
# Without this key, Wiz uses heuristic responses (no LLM features).
# Get one at https://console.anthropic.com/

# ANTHROPIC_API_KEY=sk-ant-...

# ─── OPTIONAL — Email (auth verification + scheduled reports) ────────────────
# If unset, signup will skip email verification and scheduled reports won't
# send. The simplest setup is Gmail with an app password:
#   1. Enable 2FA on your Google account
#   2. https://myaccount.google.com/apppasswords → create one for "Mail"
#   3. Use that 16-char string as SMTP_PASS

# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=you@gmail.com
# SMTP_PASS=your-16-char-app-password
# SMTP_FROM="Data Wiz <you@gmail.com>"

# ─── OPTIONAL — Hardening / scaling ──────────────────────────────────────────

# MAX_UPLOAD_SIZE_MB=100
# MAX_DATASETS_PER_TENANT=50
# MAX_CACHE_BYTES=268435456     # 256MB
# DATAWIZ_DISABLE_SCHEDULER=1   # set to disable the scheduled reports poller
