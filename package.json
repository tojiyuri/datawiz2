{
  "name": "datawiz",
  "version": "2.0.0",
  "description": "Data Wiz - AI-Powered Automated Data Visualization Platform",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "start": "node server/index.js",
    "dev": "concurrently \"npm run server:dev\" \"npm run client:dev\"",
    "server:dev": "nodemon server/index.js",
    "client:dev": "cd client && npm run dev",
    "install:all": "npm install && cd client && npm install",
    "build": "cd client && npm run build",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "csv-parser": "^3.0.0",
    "dotenv": "^16.4.5",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "uuid": "^9.0.0",
    "xlsx": "^0.18.5",
    "@anthropic-ai/sdk": "^0.32.1",
    "pg": "^8.13.1",
    "mysql2": "^3.11.5",
    "better-sqlite3": "^11.7.0",
    "axios": "^1.7.9",
    "bcrypt": "^5.1.1",
    "jsonwebtoken": "^9.0.2",
    "cookie-parser": "^1.4.7",
    "otplib": "^12.0.1",
    "qrcode": "^1.5.4",
    "nodemailer": "^6.9.16",
    "pino": "^9.5.0",
    "pino-http": "^10.3.0",
    "@sentry/node": "^8.45.0",
    "@sentry/profiling-node": "^8.45.0"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "nodemon": "^3.0.3",
    "vitest": "^2.1.8",
    "supertest": "^7.0.0"
  }
}
